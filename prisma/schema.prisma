generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ======================================================
// EMPRESA - CLIENTE
// ======================================================

model Empresa {
  id String @id @default(uuid())

  // Identificación
  nit    String @unique @db.VarChar(30)
  nombre String @db.VarChar(191)

  // Información general
  fechaInicio        DateTime? @db.Date
  direccionPrincipal String?   @db.VarChar(255)
  ciudadPrincipal    String?   @db.VarChar(120)
  correoEmpresa      String?   @db.VarChar(191)
  descripcionEmpresa String?   @db.Text

  // Actividad económica
  claseRiesgoPrincipal          ClaseRiesgo?
  codigoActividadEconomica      String?      @db.VarChar(30)
  descripcionActividadEconomica String?      @db.Text

  // Gerencia
  nombreGerente String? @db.VarChar(191)
  correoGerente String? @db.VarChar(191)

  // Contacto SST
  nombreContactoSst String? @db.VarChar(191)
  correoContactoSst String? @db.VarChar(191)

  // Visitas convenidas
  visitasSstConvenidas         Int @default(0)
  visitasEmergenciasConvenidas Int @default(0)

  // Estado
  activo Boolean @default(true)

  // Relaciones actuales
  usuarios                  Usuario[]
  asignacionesProfesionales EmpresaProfesional[]

  // Configuración y operación SG-SST
  configuracionesSgsst    ConfiguracionSgsstEmpresa[]
  evaluaciones            Evaluacion[]
  planesAccion            PlanAccion[]
  documentosEvidencia     DocumentoEvidencia[]
  obligacionesRecurrentes ObligacionRecurrente[]

  // Auditoría
  creadoEn      DateTime @default(now())
  actualizadoEn DateTime @updatedAt

  @@index([nombre])
  @@index([ciudadPrincipal])
  @@index([correoEmpresa])
  @@index([activo])
}

// ======================================================
// PROFESIONAL - PRESTADOR
// ======================================================

model Profesional {
  id String @id @default(uuid())

  // Identificación
  tipoIdentificacion   TipoIdentificacion
  numeroIdentificacion String             @unique @db.VarChar(40)

  // Información personal
  nombres   String @db.VarChar(120)
  apellidos String @db.VarChar(120)

  // Información laboral
  cargo          String? @db.VarChar(150)
  profesion      String? @db.VarChar(191)
  rolProfesional String? @db.VarChar(150)

  // Información de contacto
  correo    String  @unique @db.VarChar(191)
  celular   String? @db.VarChar(30)
  direccion String? @db.VarChar(255)

  // Estado
  activo Boolean @default(true)

  // Usuario opcional para iniciar sesión
  usuarioId String?  @unique
  usuario   Usuario? @relation(fields: [usuarioId], references: [id], onDelete: SetNull)

  // Empresas asignadas
  asignacionesEmpresas EmpresaProfesional[]

  // Operación SG-SST
  itemsEvaluacionResponsable ItemEvaluacion[]       @relation("ItemEvaluacionProfesional")
  planesAccionResponsable    PlanAccion[]           @relation("PlanAccionProfesional")
  obligacionesRecurrentes    ObligacionRecurrente[] @relation("ObligacionRecurrenteProfesional")

  // Auditoría
  creadoEn      DateTime @default(now())
  actualizadoEn DateTime @updatedAt

  @@index([apellidos, nombres])
  @@index([profesion])
  @@index([rolProfesional])
  @@index([activo])
}

// ======================================================
// ASIGNACIÓN PROFESIONAL - EMPRESA
// ======================================================

model EmpresaProfesional {
  id String @id @default(uuid())

  empresaId     String
  profesionalId String

  empresa     Empresa     @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  profesional Profesional @relation(fields: [profesionalId], references: [id], onDelete: Cascade)

  // Información de la asignación
  rolAsignacion String?   @db.VarChar(150)
  fechaInicio   DateTime? @db.Date
  fechaFin      DateTime? @db.Date
  activo        Boolean   @default(true)

  // Auditoría
  creadoEn      DateTime @default(now())
  actualizadoEn DateTime @updatedAt

  @@unique([empresaId, profesionalId], map: "uq_empresa_profesional")
  @@index([empresaId])
  @@index([profesionalId])
  @@index([activo])
}

// ======================================================
// USUARIOS Y AUTENTICACIÓN
// ======================================================

model Usuario {
  id String @id @default(uuid())

  // Credenciales
  correo     String @unique @db.VarChar(191)
  contrasena String @db.VarChar(255)

  // Información básica
  nombre String     @db.VarChar(191)
  rol    RolUsuario @default(USUARIO)

  // Empresa cliente opcional
  empresaId String?
  empresa   Empresa? @relation(fields: [empresaId], references: [id], onDelete: SetNull)

  // Perfil profesional opcional
  profesional Profesional?

  // Relaciones de auditoría y operación SG-SST
  configuracionesSgsstCreadas  ConfiguracionSgsstEmpresa[] @relation("ConfiguracionCreadaPor")
  evaluacionesCreadas          Evaluacion[]                @relation("EvaluacionCreadaPor")
  respuestasEvaluacion         RespuestaEvaluacion[]       @relation("RespuestaEvaluacionUsuario")
  planesAccionCreados          PlanAccion[]                @relation("PlanAccionCreadoPor")
  planesAccionResponsable      PlanAccion[]                @relation("PlanAccionUsuarioResponsable")
  avancesPlanAccionRegistrados AvancePlanAccion[]          @relation("AvancePlanAccionUsuario")
  documentosEvidenciaCargados  DocumentoEvidencia[]        @relation("EvidenciaCargadaPor")

  // Estado de acceso
  activo Boolean @default(true)

  // Auditoría
  creadoEn      DateTime @default(now())
  actualizadoEn DateTime @updatedAt

  @@index([empresaId])
  @@index([rol])
  @@index([activo])
}

// ======================================================
// MARCO MAESTRO DEL SG-SST
// ======================================================

model MarcoSgsst {
  id String @id @default(uuid())

  codigo      String  @db.VarChar(80)
  nombre      String  @db.VarChar(191)
  version     String  @db.VarChar(40)
  descripcion String? @db.Text

  puntajeTotal Decimal   @default(100.00) @db.Decimal(7, 2)
  vigenteDesde DateTime? @db.Date
  vigenteHasta DateTime? @db.Date
  activo       Boolean   @default(true)

  ciclos                  CicloPhva[]
  procesos                Proceso[]
  perfilesAplicabilidad   PerfilAplicabilidad[]
  bloquesDocumentales     BloqueDocumental[]
  configuracionesEmpresas ConfiguracionSgsstEmpresa[]

  creadoEn      DateTime @default(now())
  actualizadoEn DateTime @updatedAt

  @@unique([codigo, version], map: "uq_marco_codigo_version")
  @@index([activo])
}

// ======================================================
// CICLO PHVA
// ======================================================

model CicloPhva {
  id String @id @default(uuid())

  marcoId String
  marco   MarcoSgsst @relation(fields: [marcoId], references: [id], onDelete: Cascade)

  codigo             String  @db.VarChar(40)
  nombre             String  @db.VarChar(120)
  porcentajeEsperado Decimal @db.Decimal(5, 2)
  ordenVisualizacion Int

  categorias CategoriaEstandar[]

  creadoEn      DateTime @default(now())
  actualizadoEn DateTime @updatedAt

  @@unique([marcoId, codigo], map: "uq_ciclo_marco_codigo")
  @@index([marcoId, ordenVisualizacion])
}

// ======================================================
// CATEGORÍAS DE ESTÁNDARES
// ======================================================

model CategoriaEstandar {
  id String @id @default(uuid())

  cicloPhvaId String
  cicloPhva   CicloPhva @relation(fields: [cicloPhvaId], references: [id], onDelete: Cascade)

  codigo             String  @db.VarChar(50)
  nombre             String  @db.VarChar(191)
  porcentajeEsperado Decimal @db.Decimal(5, 2)
  ordenVisualizacion Int
  descripcion        String? @db.Text
  activo             Boolean @default(true)

  estandaresMinimos EstandarMinimo[]

  creadoEn      DateTime @default(now())
  actualizadoEn DateTime @updatedAt

  @@unique([cicloPhvaId, codigo], map: "uq_categoria_ciclo_codigo")
  @@index([cicloPhvaId, ordenVisualizacion])
  @@index([activo])
}

// ======================================================
// ESTÁNDARES MÍNIMOS
// ======================================================

model EstandarMinimo {
  id String @id @default(uuid())

  categoriaId String
  categoria   CategoriaEstandar @relation(fields: [categoriaId], references: [id], onDelete: Cascade)

  codigo             String  @db.VarChar(40)
  nombre             String  @db.VarChar(255)
  puntajeMaximo      Decimal @db.Decimal(7, 2)
  metaGeneral        String? @db.Text
  ordenVisualizacion Int
  activo             Boolean @default(true)

  requisitos             Requisito[]
  resultadosCalificacion CalificacionEstandarEvaluacion[]

  creadoEn      DateTime @default(now())
  actualizadoEn DateTime @updatedAt

  @@unique([categoriaId, codigo], map: "uq_estandar_categoria_codigo")
  @@index([categoriaId, ordenVisualizacion])
  @@index([activo])
}

// ======================================================
// PROCESOS SG-SST
// ======================================================

model Proceso {
  id String @id @default(uuid())

  marcoId String
  marco   MarcoSgsst @relation(fields: [marcoId], references: [id], onDelete: Cascade)

  codigo      String  @db.VarChar(40)
  nombre      String  @db.VarChar(191)
  descripcion String? @db.Text
  activo      Boolean @default(true)

  requisitos Requisito[]

  creadoEn      DateTime @default(now())
  actualizadoEn DateTime @updatedAt

  @@unique([marcoId, codigo], map: "uq_proceso_marco_codigo")
  @@index([nombre])
  @@index([activo])
}

// ======================================================
// FRECUENCIAS DE ACTUALIZACIÓN
// ======================================================

model FrecuenciaActualizacion {
  id String @id @default(uuid())

  codigo          String            @unique @db.VarChar(60)
  nombre          String            @db.VarChar(120)
  valorIntervalo  Int?
  unidadIntervalo UnidadFrecuencia?
  noAplica        Boolean           @default(false)
  descripcion     String?           @db.Text
  activo          Boolean           @default(true)

  requisitos              Requisito[]
  obligacionesRecurrentes ObligacionRecurrente[]

  creadoEn      DateTime @default(now())
  actualizadoEn DateTime @updatedAt

  @@index([activo])
}

// ======================================================
// BLOQUES DOCUMENTALES
// ======================================================

model BloqueDocumental {
  id String @id @default(uuid())

  marcoId String
  marco   MarcoSgsst @relation(fields: [marcoId], references: [id], onDelete: Cascade)

  codigo      String  @db.VarChar(50)
  nombre      String  @db.VarChar(150)
  descripcion String? @db.Text
  activo      Boolean @default(true)

  requisitos Requisito[]

  creadoEn      DateTime @default(now())
  actualizadoEn DateTime @updatedAt

  @@unique([marcoId, codigo], map: "uq_bloque_documental_marco")
  @@index([activo])
}

// ======================================================
// REQUISITOS / CRITERIOS DE VERIFICACIÓN
// ======================================================

model Requisito {
  id String @id @default(uuid())

  estandarId String
  estandar   EstandarMinimo @relation(fields: [estandarId], references: [id], onDelete: Cascade)

  procesoId String?
  proceso   Proceso? @relation(fields: [procesoId], references: [id], onDelete: SetNull)

  frecuenciaActualizacionId String?
  frecuenciaActualizacion   FrecuenciaActualizacion? @relation(fields: [frecuenciaActualizacionId], references: [id], onDelete: SetNull)

  bloqueDocumentalId String?
  bloqueDocumental   BloqueDocumental? @relation(fields: [bloqueDocumentalId], references: [id], onDelete: SetNull)

  codigo                 String  @db.VarChar(50)
  descripcion            String  @db.Text
  plantillaAccion        String? @db.Text
  guiaEjecucion          String? @db.Text
  meta                   String? @db.Text
  incluirEnInformeTareas Boolean @default(false)
  esTareaRutinaria       Boolean @default(false)
  ordenVisualizacion     Int
  filaOrigen             Int?
  activo                 Boolean @default(true)

  perfilesAplicabilidad RequisitoAplicabilidad[]
  areasGestion          RequisitoAreaGestion[]
  rolesResponsables     RequisitoRolResponsable[]
  evidenciasRequeridas  EvidenciaRequerida[]
  recursos              RecursoRequisito[]
  palabrasClave         RequisitoPalabraClave[]
  referenciasLegales    ReferenciaLegalRequisito[]
  notas                 NotaRequisito[]

  itemsEvaluacion         ItemEvaluacion[]
  planesAccion            PlanAccion[]
  obligacionesRecurrentes ObligacionRecurrente[]

  creadoEn      DateTime @default(now())
  actualizadoEn DateTime @updatedAt

  @@unique([estandarId, codigo], map: "uq_requisito_estandar_codigo")
  @@index([estandarId, ordenVisualizacion])
  @@index([procesoId])
  @@index([frecuenciaActualizacionId])
  @@index([bloqueDocumentalId])
  @@index([activo])
}

// ======================================================
// PERFILES DE APLICABILIDAD: 7, 21 Y 60 ESTÁNDARES
// ======================================================

model PerfilAplicabilidad {
  id String @id @default(uuid())

  marcoId String
  marco   MarcoSgsst @relation(fields: [marcoId], references: [id], onDelete: Cascade)

  codigo             String  @db.VarChar(40)
  nombre             String  @db.VarChar(120)
  cantidadEstandares Int?
  descripcion        String? @db.Text
  activo             Boolean @default(true)

  requisitos              RequisitoAplicabilidad[]
  configuracionesEmpresas ConfiguracionSgsstEmpresa[]

  creadoEn      DateTime @default(now())
  actualizadoEn DateTime @updatedAt

  @@unique([marcoId, codigo], map: "uq_perfil_marco_codigo")
  @@index([activo])
}

model RequisitoAplicabilidad {
  id String @id @default(uuid())

  requisitoId           String
  perfilAplicabilidadId String

  requisito           Requisito           @relation(fields: [requisitoId], references: [id], onDelete: Cascade)
  perfilAplicabilidad PerfilAplicabilidad @relation(fields: [perfilAplicabilidadId], references: [id], onDelete: Cascade)

  numeroItemPerfil   Int?
  ordenVisualizacion Int?

  creadoEn      DateTime @default(now())
  actualizadoEn DateTime @updatedAt

  @@unique([requisitoId, perfilAplicabilidadId], map: "uq_requisito_perfil")
  @@index([perfilAplicabilidadId])
}

// ======================================================
// ÁREAS DE GESTIÓN
// ======================================================

model AreaGestion {
  id String @id @default(uuid())

  codigo      String  @unique @db.VarChar(60)
  nombre      String  @db.VarChar(150)
  descripcion String? @db.Text
  activo      Boolean @default(true)

  requisitos RequisitoAreaGestion[]

  creadoEn      DateTime @default(now())
  actualizadoEn DateTime @updatedAt

  @@index([activo])
}

model RequisitoAreaGestion {
  id String @id @default(uuid())

  requisitoId   String
  areaGestionId String

  requisito   Requisito   @relation(fields: [requisitoId], references: [id], onDelete: Cascade)
  areaGestion AreaGestion @relation(fields: [areaGestionId], references: [id], onDelete: Cascade)

  creadoEn DateTime @default(now())

  @@unique([requisitoId, areaGestionId], map: "uq_requisito_area_gestion")
  @@index([areaGestionId])
}

// ======================================================
// ROLES RESPONSABLES DEL SG-SST
// ======================================================

model RolResponsable {
  id String @id @default(uuid())

  codigo      String  @unique @db.VarChar(60)
  nombre      String  @db.VarChar(150)
  descripcion String? @db.Text
  activo      Boolean @default(true)

  requisitos   RequisitoRolResponsable[]
  planesAccion PlanAccion[]

  creadoEn      DateTime @default(now())
  actualizadoEn DateTime @updatedAt

  @@index([activo])
}

model RequisitoRolResponsable {
  id String @id @default(uuid())

  requisitoId      String
  rolResponsableId String

  requisito      Requisito      @relation(fields: [requisitoId], references: [id], onDelete: Cascade)
  rolResponsable RolResponsable @relation(fields: [rolResponsableId], references: [id], onDelete: Cascade)

  esPrincipal Boolean @default(false)

  creadoEn DateTime @default(now())

  @@unique([requisitoId, rolResponsableId], map: "uq_requisito_rol_responsable")
  @@index([rolResponsableId])
}

// ======================================================
// EVIDENCIAS REQUERIDAS
// ======================================================

model EvidenciaRequerida {
  id String @id @default(uuid())

  requisitoId String
  requisito   Requisito @relation(fields: [requisitoId], references: [id], onDelete: Cascade)

  nombre              String  @db.VarChar(191)
  descripcion         String? @db.Text
  obligatoria         Boolean @default(true)
  requiereVencimiento Boolean @default(false)
  mesesRetencion      Int?
  ordenVisualizacion  Int     @default(0)

  documentosEvidencia DocumentoEvidencia[]

  creadoEn      DateTime @default(now())
  actualizadoEn DateTime @updatedAt

  @@index([requisitoId, ordenVisualizacion])
}

// ======================================================
// RECURSOS REQUERIDOS
// ======================================================

model RecursoRequisito {
  id String @id @default(uuid())

  requisitoId String
  requisito   Requisito @relation(fields: [requisitoId], references: [id], onDelete: Cascade)

  descripcion        String @db.Text
  ordenVisualizacion Int    @default(0)

  creadoEn DateTime @default(now())

  @@index([requisitoId, ordenVisualizacion])
}

// ======================================================
// PALABRAS CLAVE
// ======================================================

model PalabraClave {
  id String @id @default(uuid())

  nombre String @unique @db.VarChar(120)

  requisitos RequisitoPalabraClave[]

  creadoEn      DateTime @default(now())
  actualizadoEn DateTime @updatedAt
}

model RequisitoPalabraClave {
  id String @id @default(uuid())

  requisitoId    String
  palabraClaveId String

  requisito    Requisito    @relation(fields: [requisitoId], references: [id], onDelete: Cascade)
  palabraClave PalabraClave @relation(fields: [palabraClaveId], references: [id], onDelete: Cascade)

  creadoEn DateTime @default(now())

  @@unique([requisitoId, palabraClaveId], map: "uq_requisito_palabra_clave")
  @@index([palabraClaveId])
}

// ======================================================
// NORMATIVA Y REFERENCIAS LEGALES
// ======================================================

model NormaLegal {
  id String @id @default(uuid())

  tipoNorma    String  @db.VarChar(80)
  numero       String  @db.VarChar(80)
  anio         Int?
  nombre       String? @db.VarChar(255)
  jurisdiccion String? @db.VarChar(120)
  descripcion  String? @db.Text
  activo       Boolean @default(true)

  referenciasRequisitos ReferenciaLegalRequisito[]

  creadoEn      DateTime @default(now())
  actualizadoEn DateTime @updatedAt

  @@unique([tipoNorma, numero, anio], map: "uq_norma_legal_identidad")
  @@index([anio])
  @@index([activo])
}

model ReferenciaLegalRequisito {
  id String @id @default(uuid())

  requisitoId  String
  normaLegalId String

  requisito  Requisito  @relation(fields: [requisitoId], references: [id], onDelete: Cascade)
  normaLegal NormaLegal @relation(fields: [normaLegalId], references: [id], onDelete: Restrict)

  articulo    String? @db.VarChar(191)
  descripcion String? @db.Text

  creadoEn      DateTime @default(now())
  actualizadoEn DateTime @updatedAt

  @@index([requisitoId])
  @@index([normaLegalId])
}

// ======================================================
// NOTAS Y COMENTARIOS DEL CATÁLOGO
// ======================================================

model NotaRequisito {
  id String @id @default(uuid())

  requisitoId String
  requisito   Requisito @relation(fields: [requisitoId], references: [id], onDelete: Cascade)

  tipoNota TipoNota @default(GENERAL)
  nota     String   @db.Text
  fuente   String?  @db.VarChar(150)

  creadoEn      DateTime @default(now())
  actualizadoEn DateTime @updatedAt

  @@index([requisitoId])
  @@index([tipoNota])
}

// ======================================================
// CONFIGURACIÓN SG-SST POR EMPRESA
// ======================================================

model ConfiguracionSgsstEmpresa {
  id String @id @default(uuid())

  empresaId             String
  marcoId               String
  perfilAplicabilidadId String
  creadoPorUsuarioId    String?

  empresa             Empresa             @relation(fields: [empresaId], references: [id], onDelete: Restrict)
  marco               MarcoSgsst          @relation(fields: [marcoId], references: [id], onDelete: Restrict)
  perfilAplicabilidad PerfilAplicabilidad @relation(fields: [perfilAplicabilidadId], references: [id], onDelete: Restrict)
  creadoPorUsuario    Usuario?            @relation("ConfiguracionCreadaPor", fields: [creadoPorUsuarioId], references: [id], onDelete: SetNull)

  vigenteDesde DateTime  @db.Date
  vigenteHasta DateTime? @db.Date
  activo       Boolean   @default(true)
  notas        String?   @db.Text

  evaluaciones Evaluacion[]

  creadoEn      DateTime @default(now())
  actualizadoEn DateTime @updatedAt

  @@index([empresaId, activo])
  @@index([marcoId])
  @@index([perfilAplicabilidadId])
  @@index([creadoPorUsuarioId])
}

// ======================================================
// EVALUACIONES / DIAGNÓSTICOS
// ======================================================

model Evaluacion {
  id String @id @default(uuid())

  empresaId                   String
  configuracionSgsstEmpresaId String
  creadoPorUsuarioId          String?

  empresa                   Empresa                   @relation(fields: [empresaId], references: [id], onDelete: Restrict)
  configuracionSgsstEmpresa ConfiguracionSgsstEmpresa @relation(fields: [configuracionSgsstEmpresaId], references: [id], onDelete: Restrict)
  creadoPorUsuario          Usuario?                  @relation("EvaluacionCreadaPor", fields: [creadoPorUsuarioId], references: [id], onDelete: SetNull)

  nombre      String           @db.VarChar(191)
  anioPeriodo Int
  estado      EstadoEvaluacion @default(BORRADOR)
  iniciadaEn  DateTime?
  cerradaEn   DateTime?
  notas       String?          @db.Text

  itemsEvaluacion          ItemEvaluacion[]
  calificacionesEstandares CalificacionEstandarEvaluacion[]

  creadoEn      DateTime @default(now())
  actualizadoEn DateTime @updatedAt

  @@index([empresaId, anioPeriodo])
  @@index([configuracionSgsstEmpresaId])
  @@index([creadoPorUsuarioId])
  @@index([estado])
}

// ======================================================
// ÍTEMS DE EVALUACIÓN
// ======================================================

model ItemEvaluacion {
  id String @id @default(uuid())

  evaluacionId             String
  requisitoId              String
  profesionalResponsableId String?

  evaluacion             Evaluacion   @relation(fields: [evaluacionId], references: [id], onDelete: Cascade)
  requisito              Requisito    @relation(fields: [requisitoId], references: [id], onDelete: Restrict)
  profesionalResponsable Profesional? @relation("ItemEvaluacionProfesional", fields: [profesionalResponsableId], references: [id], onDelete: SetNull)

  estadoAplicabilidad EstadoAplicabilidad @default(APLICA)
  estadoCumplimiento  EstadoCumplimiento  @default(PENDIENTE)
  observaciones       String?             @db.Text
  fechaLimite         DateTime?           @db.Date
  evaluadoEn          DateTime?

  respuestas          RespuestaEvaluacion[]
  planesAccion        PlanAccion[]
  documentosEvidencia DocumentoEvidencia[]

  creadoEn      DateTime @default(now())
  actualizadoEn DateTime @updatedAt

  @@unique([evaluacionId, requisitoId], map: "uq_evaluacion_requisito")
  @@index([requisitoId])
  @@index([profesionalResponsableId])
  @@index([estadoCumplimiento])
}

// ======================================================
// RESPUESTAS POR TIPO DE EVALUADOR
// ======================================================

model RespuestaEvaluacion {
  id String @id @default(uuid())

  itemEvaluacionId       String
  respondidoPorUsuarioId String?

  itemEvaluacion       ItemEvaluacion @relation(fields: [itemEvaluacionId], references: [id], onDelete: Cascade)
  respondidoPorUsuario Usuario?       @relation("RespuestaEvaluacionUsuario", fields: [respondidoPorUsuarioId], references: [id], onDelete: SetNull)

  tipoEvaluador      TipoEvaluador
  estadoCumplimiento EstadoCumplimiento
  observaciones      String?            @db.Text
  respondidoEn       DateTime           @default(now())

  creadoEn      DateTime @default(now())
  actualizadoEn DateTime @updatedAt

  @@unique([itemEvaluacionId, tipoEvaluador], map: "uq_item_tipo_evaluador")
  @@index([respondidoPorUsuarioId])
}

// ======================================================
// CALIFICACIÓN POR ESTÁNDAR
// ======================================================

model CalificacionEstandarEvaluacion {
  id String @id @default(uuid())

  evaluacionId String
  estandarId   String

  evaluacion Evaluacion     @relation(fields: [evaluacionId], references: [id], onDelete: Cascade)
  estandar   EstandarMinimo @relation(fields: [estandarId], references: [id], onDelete: Restrict)

  tipoEvaluador   TipoEvaluador
  puntajeMaximo   Decimal       @db.Decimal(7, 2)
  puntajeObtenido Decimal       @default(0.00) @db.Decimal(7, 2)
  observaciones   String?       @db.Text
  calculadoEn     DateTime      @default(now())

  creadoEn      DateTime @default(now())
  actualizadoEn DateTime @updatedAt

  @@unique([evaluacionId, estandarId, tipoEvaluador], map: "uq_evaluacion_estandar_evaluador")
  @@index([estandarId])
}

// ======================================================
// PLANES DE ACCIÓN
// ======================================================

model PlanAccion {
  id String @id @default(uuid())

  empresaId                String
  requisitoId              String
  itemEvaluacionId         String?
  usuarioResponsableId     String?
  profesionalResponsableId String?
  rolResponsableId         String?
  creadoPorUsuarioId       String?

  empresa                Empresa         @relation(fields: [empresaId], references: [id], onDelete: Restrict)
  requisito              Requisito       @relation(fields: [requisitoId], references: [id], onDelete: Restrict)
  itemEvaluacion         ItemEvaluacion? @relation(fields: [itemEvaluacionId], references: [id], onDelete: SetNull)
  usuarioResponsable     Usuario?        @relation("PlanAccionUsuarioResponsable", fields: [usuarioResponsableId], references: [id], onDelete: SetNull)
  profesionalResponsable Profesional?    @relation("PlanAccionProfesional", fields: [profesionalResponsableId], references: [id], onDelete: SetNull)
  rolResponsable         RolResponsable? @relation(fields: [rolResponsableId], references: [id], onDelete: SetNull)
  creadoPorUsuario       Usuario?        @relation("PlanAccionCreadoPor", fields: [creadoPorUsuarioId], references: [id], onDelete: SetNull)

  descripcion            String          @db.Text
  prioridad              PrioridadAccion @default(MEDIA)
  estado                 EstadoAccion    @default(PENDIENTE)
  fechaInicioPlanificada DateTime?       @db.Date
  fechaLimite            DateTime?       @db.Date
  completadaEn           DateTime?
  porcentajeAvance       Int             @default(0)
  notas                  String?         @db.Text

  avances             AvancePlanAccion[]
  documentosEvidencia DocumentoEvidencia[]

  creadoEn      DateTime @default(now())
  actualizadoEn DateTime @updatedAt

  @@index([empresaId])
  @@index([requisitoId])
  @@index([itemEvaluacionId])
  @@index([usuarioResponsableId])
  @@index([profesionalResponsableId])
  @@index([rolResponsableId])
  @@index([creadoPorUsuarioId])
  @@index([estado])
  @@index([fechaLimite])
}

// ======================================================
// HISTORIAL DEL PLAN DE ACCIÓN
// ======================================================

model AvancePlanAccion {
  id String @id @default(uuid())

  planAccionId           String
  registradoPorUsuarioId String?

  planAccion           PlanAccion @relation(fields: [planAccionId], references: [id], onDelete: Cascade)
  registradoPorUsuario Usuario?   @relation("AvancePlanAccionUsuario", fields: [registradoPorUsuarioId], references: [id], onDelete: SetNull)

  porcentajeAvance Int
  notas            String?  @db.Text
  registradoEn     DateTime @default(now())

  creadoEn DateTime @default(now())

  @@index([planAccionId, registradoEn])
  @@index([registradoPorUsuarioId])
}

// ======================================================
// DOCUMENTOS Y EVIDENCIAS CARGADAS
// ======================================================

model DocumentoEvidencia {
  id String @id @default(uuid())

  empresaId            String
  itemEvaluacionId     String?
  planAccionId         String?
  evidenciaRequeridaId String?
  cargadoPorUsuarioId  String?

  empresa            Empresa             @relation(fields: [empresaId], references: [id], onDelete: Restrict)
  itemEvaluacion     ItemEvaluacion?     @relation(fields: [itemEvaluacionId], references: [id], onDelete: SetNull)
  planAccion         PlanAccion?         @relation(fields: [planAccionId], references: [id], onDelete: SetNull)
  evidenciaRequerida EvidenciaRequerida? @relation(fields: [evidenciaRequeridaId], references: [id], onDelete: SetNull)
  cargadoPorUsuario  Usuario?            @relation("EvidenciaCargadaPor", fields: [cargadoPorUsuarioId], references: [id], onDelete: SetNull)

  nombreArchivo    String          @db.VarChar(255)
  urlArchivo       String          @db.VarChar(500)
  tipoMime         String?         @db.VarChar(120)
  fechaEmision     DateTime?       @db.Date
  fechaVencimiento DateTime?       @db.Date
  estado           EstadoEvidencia @default(PENDIENTE_REVISION)
  observaciones    String?         @db.Text
  cargadoEn        DateTime        @default(now())

  creadoEn      DateTime @default(now())
  actualizadoEn DateTime @updatedAt

  @@index([empresaId])
  @@index([itemEvaluacionId])
  @@index([planAccionId])
  @@index([evidenciaRequeridaId])
  @@index([cargadoPorUsuarioId])
  @@index([estado])
  @@index([fechaVencimiento])
}

// ======================================================
// OBLIGACIONES RECURRENTES
// ======================================================

model ObligacionRecurrente {
  id String @id @default(uuid())

  empresaId             String
  requisitoId           String
  frecuenciaId          String
  profesionalAsignadoId String?

  empresa             Empresa                 @relation(fields: [empresaId], references: [id], onDelete: Restrict)
  requisito           Requisito               @relation(fields: [requisitoId], references: [id], onDelete: Restrict)
  frecuencia          FrecuenciaActualizacion @relation(fields: [frecuenciaId], references: [id], onDelete: Restrict)
  profesionalAsignado Profesional?            @relation("ObligacionRecurrenteProfesional", fields: [profesionalAsignadoId], references: [id], onDelete: SetNull)

  ultimaCompletadaEn   DateTime?
  proximoVencimientoEn DateTime?
  activo               Boolean   @default(true)
  notas                String?   @db.Text

  creadoEn      DateTime @default(now())
  actualizadoEn DateTime @updatedAt

  @@unique([empresaId, requisitoId], map: "uq_empresa_requisito_obligacion")
  @@index([frecuenciaId])
  @@index([profesionalAsignadoId])
  @@index([proximoVencimientoEn])
  @@index([activo])
}

